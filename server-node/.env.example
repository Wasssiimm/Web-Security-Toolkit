# Copy this file to .env and fill in the values

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development               # Set to "production" on the server

# ── Services ──────────────────────────────────────────────────────────────────
PYTHON_API_URL=http://localhost:8000
PYTHON_ENV=development             # Set to "production" on the server

# ── Security ──────────────────────────────────────────────────────────────────
# Shared secret between Node and Python — Python rejects requests without it.
# Generate a strong random value: node -e "console.log(require('crypto').randomUUID())"
# REQUIRED in production — server refuses to start if missing.
INTERNAL_API_TOKEN=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Dev: the Vite dev server. Prod: your live domain.
# Multiple origins: comma-separated  →  https://crucex.dev,https://www.crucex.dev
# REQUIRED in production — server refuses to start if missing.
CORS_ORIGIN=http://localhost:5173

# ── Rate limits (requests per 15-minute window per IP) ────────────────────────
RATE_LIMIT_GLOBAL=200              # Applied to all routes combined
RATE_LIMIT_SCAN=10                 # /api/scan/* — nmap + external HTTP are heavy
RATE_LIMIT_PASSWORD=40             # /api/password/*

# ── Concurrency ───────────────────────────────────────────────────────────────
MAX_CONCURRENT_SCANS=3             # Max simultaneous nmap scans (each can run 30s)
