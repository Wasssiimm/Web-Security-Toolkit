# Production compose environment — lives ONLY on the VPS as `.env` next to
# docker-compose.yml. Never commit the real file (it's gitignored).
# The GitHub Actions deploy workflow does not create this for you — set it
# up on the server once, by hand, before the first deploy.

# ── Image source ───────────────────────────────────────────────────────────
# Your Docker Hub username — the same account the CI workflow pushes images to.
DOCKERHUB_USERNAME=

# Which tag docker-compose should pull. The deploy workflow overrides this
# per-run; leave as "latest" for manual `docker-compose up` on the box.
IMAGE_TAG=latest

# ── Security ─────────────────────────────────────────────────────────────────
# Shared secret between the node and python containers.
# Generate with: node -e "console.log(require('crypto').randomUUID())"
INTERNAL_API_TOKEN=

# ── Error tracking (Sentry) — optional, leave empty to disable ─────────────
SENTRY_DSN=

# ── Logging (Betterstack Logtail) — optional, leave empty to disable ───────
LOGTAIL_SOURCE_TOKEN=
LOGTAIL_INGESTING_HOST=
