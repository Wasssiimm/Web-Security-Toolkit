# Copy this file to .env and fill in the values

# ── Server ────────────────────────────────────────────────────────────────────
PYTHON_ENV=development             # Set to "production" on the server

# ── Security ──────────────────────────────────────────────────────────────────
# Must match INTERNAL_API_TOKEN in server-node/.env
# REQUIRED in production — server refuses to start if missing.
INTERNAL_API_TOKEN=

# ── Error tracking (Sentry) ───────────────────────────────────────────────────
# Same DSN as server-node — one Sentry project covers both services
# Get your DSN at https://sentry.io → Project → Settings → Client Keys
SENTRY_DSN=
